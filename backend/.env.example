APP_ENV=development
APP_PORT=8080

DATABASE_URL=postgres://postgres:postgres@localhost:5433/documentes?sslmode=disable

JWT_ACCESS_SECRET=change-me-to-random-64-char-string-in-production-please-do-not-reuse
JWT_REFRESH_SECRET=change-me-too-another-random-64-char-string-different-from-access
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./storage/documents
MAX_UPLOAD_MB=20

CORS_ALLOWED_ORIGINS=http://localhost:3000,https://localhost:3000

# Comma-separated IPs/CIDRs of the reverse proxy allowed to set X-Forwarded-For.
# Leave EMPTY when clients hit the backend directly (dev). Behind nginx set it,
# e.g. TRUSTED_PROXIES=127.0.0.1 — otherwise every user shares the proxy's IP
# for rate limiting and download logs.
TRUSTED_PROXIES=

# Azure AD (leave empty to disable Azure login)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_AUTO_PROVISION=true
