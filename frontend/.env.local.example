# Base URL that the BROWSER uses to call the API.
# Same-origin deploy (recommended): leave it relative so requests go through
# the Next.js rewrites in next.config.mjs.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1

# Backend origin used by next.config.mjs rewrites (server-side proxy target).
# Baked in at BUILD time for production builds.
BACKEND_URL=http://localhost:8080

# Sub-path the app is served under (e.g. /Document). Empty = served at root.
# Baked in at BUILD time — rebuild after changing.
NEXT_PUBLIC_BASE_PATH=
